PORT=4000

# Supabase project settings (Project Settings > API in the Supabase dashboard).
# Also used to verify Supabase Auth access tokens for the /auth/* and
# /business/* routes (README §14) -- no separate auth-specific key needed,
# since token verification just calls the same project's Auth API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required in the X-Admin-Token header for the /admin/claims
# routes (business claim review). No admin auth system exists yet -- generate
# a long random value and keep it out of version control.
ADMIN_API_TOKEN=
