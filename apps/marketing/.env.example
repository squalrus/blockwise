# Absolute URL of the app (apps/web). Used to build login/signup links since
# the marketing site and the app are separate domains/deploys.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GA4 measurement ID for tryspored.com (Google Analytics dashboard > Admin >
# Data streams). Separate property/stream from apps/web's
# NEXT_PUBLIC_GA_MEASUREMENT_ID -- this one tracks anonymous marketing-site
# traffic, not in-app usage. GoogleAnalytics is a no-op when unset (see
# src/app/layout.tsx), so this can be left blank in local dev.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
